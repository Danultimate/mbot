# Matchbook Exchange API Credentials
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control

MATCHBOOK_USER=your_username
MATCHBOOK_PASSWORD=your_password

# Dashboard password (optional). If set, dashboard requires this password to access.
# Leave empty to disable password protection (e.g. for local dev).
# DASHBOARD_PASSWORD=your_secure_password

# Alerts (optional). Configure one or more channels. Unset = channel skipped.
# Telegram: create bot via @BotFather, get token. Chat ID from @userinfobot or group.
# ALERT_TELEGRAM_BOT_TOKEN=your_bot_token
# ALERT_TELEGRAM_CHAT_ID=your_chat_id
# Discord: create webhook in channel settings.
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Email: SMTP config (e.g. Gmail with app password).
# ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
# ALERT_EMAIL_SMTP_PORT=587
# ALERT_EMAIL_USER=your_email@gmail.com
# ALERT_EMAIL_PASSWORD=your_app_password
# ALERT_EMAIL_FROM=your_email@gmail.com
# ALERT_EMAIL_TO=recipient@example.com
